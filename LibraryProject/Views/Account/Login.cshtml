@model LoginViewModel
@{
    Layout = null;

    var posters = new[]
    {
        new { Img = "lib1.png", Quote = "Cennetin bir kütüphane gibi bir yer olduğunu hep hayal etmişimdir.", Author = "Jorge Luis Borges" },
        new { Img = "lib2.jpg", Quote = "Kitaplar, en sessiz ve en sadık dostlardır.", Author = "Charles W. Eliot" },
        new { Img = "lib3.jpg", Quote = "Bugün okuyan biri, yarın önderlik eden biri olur.", Author = "Margaret Fuller" },
        new { Img = "lib4.jpg", Quote = "Bir odada kitap yoksa, o odanın ruhu yoktur.", Author = "Cicero" },
        new { Img = "lib5.jpg", Quote = "Okumak aklı bilgiyle doldurur; düşünmek onu bizim yapar.", Author = "John Locke" },
        new { Img = "lib6.jpg", Quote = "Kitaplar uygarlığa yön veren ışıklardır.", Author = "Franklin D. Roosevelt" }
    };
    var poster = posters[Random.Shared.Next(posters.Length)];
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Kütüphane</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-split">

        <!-- SOL: fotoğraf -->
        <div class="brand-side" style="background-image: url('/img/auth/@poster.Img');">
            <a class="brand-logo" href="/">
                <i class="bi bi-book-half"></i> Kütüphane
            </a>
        </div>

        <!-- SAĞ: söz + form -->
        <div class="form-side">
            <div class="form-inner">

                <blockquote class="auth-quote">
                    <p>"@poster.Quote"</p>
                    <footer>— @poster.Author</footer>
                </blockquote>

                <h4 class="fw-bold mb-1">Giriş Yap</h4>
                <p class="text-muted mb-4">Hesabına giriş yaparak devam et</p>

                <form asp-controller="Account" asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">E-posta</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="ornek@mail.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Şifre</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Beni hatırla</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right"></i> Giriş Yap
                    </button>
                </form>

                <p class="text-center mt-3 mb-0">
                    Hesabın yok mu? <a asp-controller="Account" asp-action="Register" class="fw-semibold">Kayıt Ol</a>
                </p>
            </div>
        </div>
    </div>
</body>
</html>