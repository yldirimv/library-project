@using LibraryProject.Model.Dtos
@model List<Seat>
@{
    var states = ViewData["SeatStates"] as Dictionary<int, SeatStateDto>
                 ?? new Dictionary<int, SeatStateDto>();
    var floor = (int)(ViewData["Floor"] ?? 1);
}

<div class="seat-map">
    @if (floor == 1)
    {
        <!-- Yapısal elemanlar -->
        <div class="decor block" style="left:20px;top:20px;width:300px;height:110px;">MERDİVEN</div>
        <div class="decor block" style="left:520px;top:20px;width:120px;height:100px;">WC</div>
        <div class="decor block" style="left:660px;top:20px;width:120px;height:100px;">WC</div>
        <div class="decor block" style="left:800px;top:20px;width:120px;height:100px;">WC</div>

        <!-- Kitaplık şeritleri -->
        <div class="decor shelf shelf-h" style="left:30px;top:150px;width:280px;height:16px;"></div>
        <div class="decor shelf shelf-v" style="left:12px;top:180px;width:16px;height:560px;"></div>
        <div class="decor shelf shelf-v" style="left:1008px;top:150px;width:16px;height:560px;"></div>
        <span class="shelf-label" style="left:990px;top:360px;">KİTAPLIKLAR</span>

        <!-- Masalar (koltuk koordinatlarıyla hizalı) -->
        <div class="decor table" style="left:80px;top:230px;"></div>
        <div class="decor table" style="left:80px;top:420px;"></div>
        <div class="decor table" style="left:80px;top:610px;"></div>
        <div class="decor table-duo" style="left:420px;top:200px;"></div>
        <div class="decor table-duo" style="left:610px;top:200px;"></div>
        <div class="decor table-duo" style="left:800px;top:200px;"></div>
        <div class="decor table" style="left:430px;top:380px;"></div>
        <div class="decor table" style="left:430px;top:570px;"></div>
        <div class="decor table" style="left:720px;top:380px;"></div>
        <div class="decor table" style="left:720px;top:570px;"></div>

        <!-- Alt bölge -->
        <div class="decor entrance" style="left:150px;top:830px;width:130px;">GİRİŞ</div>
        <div class="decor block" style="left:380px;top:790px;width:200px;height:70px;">RESEPSİYON</div>
        <div class="decor block" style="left:700px;top:740px;width:250px;height:130px;">OTURMA ALANI / LOUNGE</div>
    }

    @if (floor == 2)
{
    <!-- Yapısal elemanlar -->
    <div class="decor block" style="left:20px;top:20px;width:280px;height:110px;">MERDİVEN</div>
    <div class="decor window" style="left:420px;top:12px;width:400px;height:10px;"></div>
    <span class="decor" style="left:580px;top:26px;font-size:.65rem;color:#8d8879;font-weight:700;">PENCERE</span>

    <!-- Kitaplık şeritleri: sol duvar + merdiven altı -->
    <div class="decor shelf shelf-h" style="left:30px;top:150px;width:250px;height:16px;"></div>
    <div class="decor shelf shelf-v" style="left:12px;top:180px;width:16px;height:560px;"></div>

    <!-- Masalar -->
    <div class="decor table" style="left:380px;top:110px;"></div>
    <div class="decor table" style="left:640px;top:110px;"></div>
    <div class="decor table" style="left:80px;top:280px;"></div>
    <div class="decor table" style="left:80px;top:470px;"></div>
    <div class="decor table" style="left:80px;top:660px;"></div>
    <div class="decor table" style="left:350px;top:330px;"></div>
    <div class="decor table" style="left:350px;top:520px;"></div>
    <div class="decor table" style="left:350px;top:710px;"></div>

    <!-- Teras + Kantin bölgesi (rezerve edilemez alan) -->
    <div class="decor zone" style="left:620px;top:250px;width:400px;height:450px;">
        <span class="zone-title">TERAS + KANTİN</span>
        <div class="decor round-table" style="left:60px;top:200px;"></div>
        <div class="decor round-table" style="left:180px;top:260px;"></div>
        <div class="decor round-table" style="left:300px;top:200px;"></div>
    </div>
    <div class="decor block" style="left:680px;top:740px;width:280px;height:110px;">KANTİN</div>

    
}

    <!-- Koltuklar: DB'den -->
    @foreach (var seat in Model)
{
    var info = states.TryGetValue(seat.Id, out var s) ? s : new SeatStateDto();
    var tooltip = info.State == "free"
        ? $"{seat.SeatNumber} — Boş"
        : $"{seat.SeatNumber} — {info.VisitorName} ({info.TimeRange})";

    <div class="seat @info.State"
         style="left:@(seat.PosX)px;top:@(seat.PosY)px;"
         data-seat-id="@seat.Id"
         data-seat-number="@seat.SeatNumber"
         title="@tooltip">
        @seat.SeatNumber.Split('-')[1]
    </div>
}
</div>

<div class="seat-legend mt-3">
    <span><i class="dot free"></i> Boş</span>
    <span><i class="dot reserved"></i> Rezerve</span>
    <span><i class="dot occupied"></i> Dolu</span>
    <span><i class="dot break"></i> Molada</span>
</div>