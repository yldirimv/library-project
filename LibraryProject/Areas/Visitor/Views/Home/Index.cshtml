@model List<Reservation>
@{ ViewData["Title"] = "Ana Sayfa"; 
var activeLoans = (List<BookLoan>)ViewBag.ActiveLoans;
}

<div class="page-header">
    <h2><i class="bi bi-house"></i> Ana Sayfa</h2>
    <a asp-controller="Reservation" asp-action="Index" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Yeni Rezervasyon
    </a>
</div>
@if (activeLoans.Any())
{
    <div class="card mb-4">
        <div class="card-body d-flex flex-wrap align-items-center gap-3">
            <i class="bi bi-journal-bookmark fs-4" style="color:var(--accent)"></i>
            <span class="fw-semibold">Üzerimdeki kitaplar:</span>
            @foreach (var loan in activeLoans)
            {
                var overdue = DateTime.Now > loan.DueDate;
                <span class="badge @(overdue ? "bg-danger" : "bg-success")">
                    @loan.Book.Title — son: @loan.DueDate.ToString("dd.MM")
                </span>
            }
            <a asp-controller="MyBooks" asp-action="Index" class="ms-auto small">Tümü →</a>
        </div>
    </div>
}

<h5 class="fw-bold mb-3"><i class="bi bi-calendar-week"></i> Rezervasyonlarım</h5>
<table class="table table-striped">
    <thead>
        <tr><th>Koltuk</th><th>Tarih</th><th>Saat</th><th>Durum</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var res in Model)
        {
            <tr>
                <td><strong>@res.Seat.SeatNumber</strong></td>
                <td>@res.StartTime.ToString("dd.MM.yyyy")</td>
                <td>@res.StartTime.ToString("HH:mm") - @res.EndTime.ToString("HH:mm")</td>
                <td>
                    @switch (res.Status)
                    {
                        case ReservationStatus.Pending:   <span class="badge bg-secondary">Bekliyor</span> break;
                        case ReservationStatus.Active:    <span class="badge bg-danger">İçeride</span> break;
                        case ReservationStatus.OnBreak:   <span class="badge bg-primary">Molada</span> break;
                        case ReservationStatus.Completed: <span class="badge bg-success">Tamamlandı</span> break;
                        case ReservationStatus.Cancelled: <span class="badge bg-light text-dark">İptal</span> break;
                        case ReservationStatus.NoShow:    <span class="badge bg-warning text-dark">Gelmedi</span> break;
                    }
                </td>
                <td class="text-end">
                    @if (res.Status == ReservationStatus.Pending)
                    {
                        <form asp-action="Cancel" asp-route-id="@res.Id" method="post" class="d-inline"
                              data-confirm="Rezervasyon iptal edilsin mi?">
                            <button type="submit" class="btn btn-sm btn-outline-danger">İptal Et</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted text-center">Henüz rezervasyonunuz yok.</p>
}