<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kütüphane Ziyaretçi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <aside class="app-sidebar">
        <a class="brand" asp-area="Visitor" asp-controller="Home" asp-action="Index">
            <i class="bi bi-book-half"></i> Kütüphane
        </a>

        <nav class="nav flex-column">
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
       asp-area="Visitor" asp-controller="Home" asp-action="Index">
        <i class="bi bi-house"></i> Ana Sayfa
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservation" ? "active" : "")"
       asp-area="Visitor" asp-controller="Reservation" asp-action="Index">
        <i class="bi bi-calendar-plus"></i> Rezervasyon Yap
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MyBooks" ? "active" : "")"
       asp-area="Visitor" asp-controller="MyBooks" asp-action="Index">
        <i class="bi bi-journal-bookmark"></i> Kitaplarım
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" ? "active" : "")"
       asp-area="Visitor" asp-controller="Announcement" asp-action="Index">
        <i class="bi bi-megaphone"></i> Duyurular
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Loyalty" ? "active" : "")"
       asp-area="Visitor" asp-controller="Loyalty" asp-action="Index">
        <i class="bi bi-gift"></i> Sadakat Sistemi
    </a>
</nav>

<form asp-area="Visitor" asp-controller="Noise" asp-action="Report" method="post" class="px-2 mb-2"
    data-confirm="Bulunduğunuz bölgedeki gürültüyü bildirmek istiyor musunuz?">
    <button type="submit" class="btn btn-danger w-100">
        <i class="bi bi-volume-up"></i> Gürültü İhbar Et
    </button>
</form>

        <div class="sidebar-footer">
            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="nav-link border-0 bg-transparent w-100">
                    <i class="bi bi-box-arrow-left"></i> Çıkış Yap
                </button>
            </form>
        </div>
    </aside>

    <main class="app-main">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/confirm-modal.js" asp-append-version="true"></script>

    <!-- Chatbot -->
    <button id="chatToggle" class="chat-toggle" title="Kütüphane Asistanı">
        <i class="bi bi-chat-dots-fill"></i>
    </button>

    <div id="chatPanel" class="chat-panel">
        <div class="chat-header">
            <i class="bi bi-robot"></i> Kütüphane Asistanı
            <button id="chatClose" class="btn-close btn-close-white ms-auto"></button>
        </div>
        <div id="chatMessages" class="chat-messages">
            <div class="chat-msg bot">
                Merhaba! 👋 Kütüphane kuralları, rezervasyon, mola,
                puan sistemi veya kitaplarımız hakkında bana soru sorabilirsiniz.
            </div>
        </div>
        <form id="chatForm" class="chat-input">
            <input type="text" id="chatInput" class="form-control"
                   placeholder="Sorunuzu yazın..." autocomplete="off" />
            <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i></button>
        </form>
    </div>

    <script>
            (function () {
                const toggle = document.getElementById('chatToggle');
                const panel = document.getElementById('chatPanel');
                const messages = document.getElementById('chatMessages');
                const form = document.getElementById('chatForm');
                const input = document.getElementById('chatInput');

                toggle.addEventListener('click', () => panel.classList.toggle('open'));
                document.getElementById('chatClose').addEventListener('click',
                    () => panel.classList.remove('open'));

                function addMsg(text, who) {
                    const div = document.createElement('div');
                    div.className = 'chat-msg ' + who;
                    div.textContent = text;
                    messages.appendChild(div);
                    messages.scrollTop = messages.scrollHeight;
                    return div;
                }

                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const q = input.value.trim();
                    if (!q) return;

                    addMsg(q, 'user');
                    input.value = '';
                    const thinking = addMsg('Yazıyor...', 'bot thinking');

                    try {
                        const res = await fetch('/Visitor/Chatbot/Ask', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ question: q })
                        });
                        const data = await res.json();
                        thinking.textContent = data.answer;
                        thinking.classList.remove('thinking');
                    } catch {
                        thinking.textContent = 'Bir hata oluştu, tekrar deneyin.';
                        thinking.classList.remove('thinking');
                    }
                });
            })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>