@model List<Announcement>
@{ ViewData["Title"] = "Duyurular"; }

<div class="page-header">
    <h2><i class="bi bi-megaphone"></i> Duyurular</h2>
</div>

@foreach (var item in Model)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <h5 class="fw-bold mb-1">@item.Title</h5>
                <small class="text-muted">@item.CreatedDate.ToString("dd.MM.yyyy")</small>
            </div>
            <p class="mb-0 text-muted">@item.Content</p>
        </div>
    </div>
}

@if (!Model.Any())
{
    <p class="text-muted text-center">Henüz duyuru yok.</p>
}