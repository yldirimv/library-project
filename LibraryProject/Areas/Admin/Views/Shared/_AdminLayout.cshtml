<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kütüphane Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <aside class="app-sidebar">
        <a class="brand" asp-area="Admin" asp-controller="Home" asp-action="Index">
            <i class="bi bi-book-half"></i> Kütüphane
        </a>

        <nav class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-area="Admin" asp-controller="Home" asp-action="Index">
                <i class="bi bi-speedometer2"></i> Ana Sayfa
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" ? "active" : "")"
               asp-area="Admin" asp-controller="Announcement" asp-action="Index">
                <i class="bi bi-megaphone"></i> Duyurular
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Book" ? "active" : "")"
               asp-area="Admin" asp-controller="Book" asp-action="Index">
                <i class="bi bi-book"></i> Kitap Yönetimi
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" ? "active" : "")"
               asp-area="Admin" asp-controller="Employee" asp-action="Index">
                <i class="bi bi-person-badge"></i> Çalışanlar
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Visitor" ? "active" : "")"
               asp-area="Admin" asp-controller="Visitor" asp-action="Index">
                <i class="bi bi-people"></i> Ziyaretçiler
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "LibraryStatus" ? "active" : "")"
               asp-area="Admin" asp-controller="LibraryStatus" asp-action="Index">
                <i class="bi bi-grid-3x3-gap"></i> Kütüphane Durum
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Loyalty" ? "active" : "")"
               asp-area="Admin" asp-controller="Loyalty" asp-action="Index">
                <i class="bi bi-gift"></i> Sadakat Sistemi
            </a>
        </nav>

        <div class="sidebar-footer">
            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="nav-link border-0 bg-transparent w-100">
                    <i class="bi bi-box-arrow-left"></i> Çıkış Yap
                </button>
            </form>
        </div>
    </aside>

    <main class="app-main">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/confirm-modal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>