@model List<Announcement>
@{
    ViewData["Title"] = "Duyurular";
}

<div class="page-header">
    <h2><i class="bi bi-megaphone"></i> Duyurular</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Yeni Duyuru</a>
</div>



<table class="table table-striped">
    <thead>
        <tr><th>Başlık</th><th>Tarih</th><th>Durum</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    @if (!item.IsActive)
                    {
                        <span class="badge bg-secondary">Silinmiş</span>
                    }
                    else if (item.IsPublished)
                    {

                        <span class="badge bg-success">Yayında</span>
                    }
                    else
                    {

                        <span class="badge bg-warning">Taslak</span>
                    }
                </td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                          data-confirm="Bu duyuru silinsin mi?">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>