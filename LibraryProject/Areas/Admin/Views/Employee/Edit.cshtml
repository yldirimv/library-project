@model EmployeeEditViewModel
@{ ViewData["Title"] = "Çalışan Bilgilerini Düzenle"; }

<div class="page-header">
    <h2><i class="bi bi-person-plus"></i> Çalışan Düzenle</h2>
</div>

<div class="card col-md-6">
    <div class="card-body">
        <form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label">Ad Soyad</label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">E-posta</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Güncelle</button>
            <a asp-action="Index" class="btn btn-secondary">İptal</a>
        </form>
    </div>
</div>