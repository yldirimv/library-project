<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kütüphane Personel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <aside class="app-sidebar">
        <a class="brand" asp-area="Employee" asp-controller="Home" asp-action="Index">
            <i class="bi bi-book-half"></i> Kütüphane
        </a>

        <nav class="nav flex-column">
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
       asp-area="Employee" asp-controller="Home" asp-action="Index">
        <i class="bi bi-speedometer2"></i> Ana Sayfa
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "BookLoan" ? "active" : "")"
       asp-area="Employee" asp-controller="BookLoan" asp-action="Index">
        <i class="bi bi-arrow-left-right"></i> Kitap Ödünç
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ReservationTracking" ? "active" : "")"
       asp-area="Employee" asp-controller="ReservationTracking" asp-action="Index">
        <i class="bi bi-calendar-check"></i> Rezervasyon Takip
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" ? "active" : "")"
       asp-area="Employee" asp-controller="Announcement" asp-action="Index">
        <i class="bi bi-megaphone"></i> Duyurular
    </a>
</nav>

        <div class="sidebar-footer">
            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="nav-link border-0 bg-transparent w-100">
                    <i class="bi bi-box-arrow-left"></i> Çıkış Yap
                </button>
            </form>
        </div>
    </aside>

    <main class="app-main">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/confirm-modal.js" asp-append-version="true"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/notification")
        .withAutomaticReconnect()
        .build();

    connection.on("NoiseReport", (data) => {
        // Pop-up: sağ üstte kayan uyarı kartı
        const toast = document.createElement('div');
        toast.className = 'noise-toast';
        toast.innerHTML = `
            <i class="bi bi-volume-up-fill"></i>
            <div>
                <strong>Gürültü İhbarı!</strong><br>
                <span>${data.seatNumber} koltuğundan — ${data.time}</span>
            </div>`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 10000); // 10 sn sonra kaybolur
    });
    // Ana sayfadaysa listeyi tazelemek için 3 sn sonra sayfayı yenile
        if (window.location.pathname.toLowerCase().includes('/employee/home')
            || window.location.pathname.toLowerCase() === '/employee') {
            setTimeout(() => window.location.reload(), 3000);
        }

    connection.start().then(() => connection.invoke("JoinEmployeeGroup"));
</script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>